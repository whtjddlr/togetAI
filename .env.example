# Neon pooled connection string for the Next.js runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection string for Prisma CLI commands such as migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5 인증 설정입니다. 비워두면 게스트 모드가 기본으로 동작합니다.
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# B3에서 사용: 익명 참여 키 HMAC 서명용 시크릿입니다.
ANON_KEY_SECRET=""

# E2E 전용, 프로덕션 금지. "1"일 때만 테스트 Credentials 로그인을 켭니다.
AUTH_TEST_LOGIN=""

GMS_API_KEY=""
GMS_API_URL="https://gms.ssafy.io/gmsapi/api.openai.com/v1/responses"
GMS_DEFAULT_MODEL="gpt-4.1"

# Upstash Redis REST 설정입니다. 비워두면 인메모리 rate limit fallback을 사용합니다.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
